generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                     String       @id @default(cuid())
  email                  String       @unique
  passwordHash           String?
  fullName               String?
  isActive               Boolean      @default(true)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  bankIdSubject          String?      @unique
  emailVerificationToken String?      @unique
  emailVerifiedAt        DateTime?
  auditLogs              AuditLog[]
  memberships            Membership[]
  sessions               Session[]
}

model Membership {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       String   @default("owner")
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  userId     String?
  entityType String
  entityId   String
  action     String
  beforeJson String?
  afterJson  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, entityType])
  @@index([businessId, createdAt])
}

model PeriodLock {
  id             String   @id @default(cuid())
  businessId     String
  periodStart    DateTime
  periodEnd      DateTime
  lockedAt       DateTime @default(now())
  lockedByUserId String?
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Filing {
  id           String    @id @default(cuid())
  businessId   String
  filingType   String
  periodStart  DateTime
  periodEnd    DateTime
  status       String    @default("DRAFT")
  externalRef  String?
  payloadJson  String?
  responseJson String?
  submittedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, filingType])
  @@index([businessId, status])
}

model TaxEvent {
  id         String    @id @default(cuid())
  businessId String
  source     String
  eventType  String
  eventRef   String?
  title      String
  detail     String?
  eventDate  DateTime?
  createdAt  DateTime  @default(now())
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, eventDate])
}

model BankStatementLine {
  id                   String    @id @default(cuid())
  businessId           String
  txnDate              DateTime
  bookingDate          DateTime?
  description          String
  amount               Decimal
  currency             String    @default("SEK")
  externalId           String?
  matchedTransactionId String?
  status               String    @default("UNMATCHED")
  createdAt            DateTime  @default(now())
  business             Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
  @@index([businessId, txnDate])
}

model Business {
  id                        String                @id @default(cuid())
  name                      String
  orgType                   String                @default("sole_trader")
  jurisdiction              String                @default("SWEDEN")
  bookkeepingMethod         String                @default("kontantmetoden")
  vatRegistered             Boolean               @default(true)
  vatFrequency              String                @default("yearly")
  fiscalYearStart           DateTime
  baseCurrency              String                @default("SEK")
  locale                    String                @default("en")
  invoiceNumberPattern      String                @default("INV-{YYYY}-{SEQ:4}")
  nextInvoiceSequence       Int                   @default(1)
  invoiceSenderName         String?
  invoiceSenderAddress      String?
  invoiceSenderOrgNumber    String?
  invoiceSenderEmail        String?
  invoiceSenderPhone        String?
  invoiceSenderWebsite      String?
  invoiceDefaultLogo        String?
  invoiceDefaultSignature   String?
  invoiceEmailFrom          String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  sniCode                   String?
  vatNumber                 String?
  fSkattRegistered          Boolean               @default(true)
  personnummer              String?
  bankgiro                  String?
  peppolId                  String?
  plusgiro                  String?
  skvActorId                String?
  skvAuthorizationStatus    String?
  countryCode               String?
  countryResolutionSource   String?
  lastCountryConfirmedAt    DateTime?
  taxProfileTemplateVersion String?
  accounts                  Account[]
  auditLogs                 AuditLog[]
  bankImports               BankImportBatch[]
  bankStatementLines        BankStatementLine[]
  countryTaxProfile         CountryTaxProfile?
  customers                 Customer[]
  employees                 Employee[]
  employeeExpenses          EmployeeExpense[]
  employerDeclarations      EmployerDeclaration[]
  filings                   Filing[]
  fixedAssets               FixedAsset[]
  invoices                  Invoice[]
  memberships               Membership[]
  mileageEntries            MileageEntry[]
  openingBalances           OpeningBalance[]
  payslips                  Payslip[]
  periodLocks               PeriodLock[]
  periodisationEntries      PeriodisationEntry[]
  receipts                  Receipt[]
  salaryEntries             SalaryEntry[]
  subscriptions             Subscription?
  taxConfig                 TaxConfig?
  taxEvents                 TaxEvent[]
  transactions              Transaction[]
}

model Subscription {
  id                   String    @id @default(cuid())
  businessId           String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 String    @default("free")
  status               String    @default("active")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  business             Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Payslip {
  id              String   @id @default(cuid())
  businessId      String
  salaryEntryId   String   @unique
  employeeId      String
  periodFrom      DateTime
  periodTo        DateTime
  paymentDate     DateTime
  grossSalary     Decimal
  taxableGross    Decimal
  taxWithheld     Decimal
  employerContrib Decimal
  pensionAmount   Decimal
  netSalary       Decimal
  pdfKey          String?
  generatedAt     DateTime @default(now())
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, paymentDate])
  @@index([employeeId])
}

model EmployerDeclaration {
  id           String    @id @default(cuid())
  businessId   String
  periodYear   Int
  periodMonth  Int
  status       String    @default("DRAFT")
  totalGross   Decimal   @default(0)
  totalTax     Decimal   @default(0)
  totalContrib Decimal   @default(0)
  payloadJson  String?
  responseJson String?
  externalRef  String?
  submittedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, periodYear, periodMonth])
  @@index([businessId, status])
}

model TaxConfig {
  id                     String   @id @default(cuid())
  businessId             String   @unique
  municipalTaxRate       Decimal  @default(0.32)
  socialContributionRate Decimal  @default(0.2897)
  generalDeductionRate   Decimal  @default(0.25)
  vatStandardRate        Decimal  @default(0.25)
  vatReducedRateFood     Decimal  @default(0.12)
  vatReducedRateCulture  Decimal  @default(0.06)
  updatedAt              DateTime @updatedAt
  business               Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model CountryTaxProfile {
  id                         String          @id @default(cuid())
  businessId                 String          @unique
  countryCode                String
  templateFamily             String?
  templateVersion            String          @default("1.0.0")
  vatStandardRate            Decimal         @default(0.25)
  vatReducedRate1            Decimal?
  vatReducedRate2            Decimal?
  vatReducedRate3            Decimal?
  vatRegistrationThreshold   Decimal?
  vatCashAccounting          Boolean         @default(false)
  ossEnabled                 Boolean         @default(false)
  reverseChargeEnabled       Boolean         @default(false)
  taxYearStartMonth          Int             @default(1)
  taxYearEndMonth            Int             @default(12)
  vatFilingFrequency         String          @default("yearly")
  vatPaymentDueDays          Int             @default(30)
  incomeTaxMode              String          @default("flat")
  flatIncomeTaxRate          Decimal?
  municipalSurchargeRate     Decimal?
  nationalSurchargeRate      Decimal?
  nationalSurchargeThreshold Decimal?
  socialContributionRate     Decimal         @default(0)
  socialContributionCap      Decimal?
  pensionContributionRate    Decimal         @default(0)
  pensionContributionCap     Decimal?
  generalDeductionRate       Decimal         @default(0)
  employerContributionRate   Decimal         @default(0)
  employeeWithholdingRate    Decimal         @default(0)
  personalTaxIdLabel         String?
  businessRegIdLabel         String?
  vatIdLabel                 String?
  socialContribLabel         String?
  customFieldsJson           String?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  business                   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  incomeTaxBands             IncomeTaxBand[]

  @@index([businessId])
  @@index([countryCode])
}

model IncomeTaxBand {
  id         String            @id @default(cuid())
  profileId  String
  bandOrder  Int
  fromAmount Decimal
  toAmount   Decimal?
  rate       Decimal
  label      String?
  profile    CountryTaxProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, bandOrder])
}

model Account {
  id              String           @id @default(cuid())
  businessId      String
  code            String
  name            String
  type            String
  vatCode         String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lines           JournalLine[]
  openingBalances OpeningBalance[]

  @@unique([businessId, code])
}

model Receipt {
  id               String        @id @default(cuid())
  businessId       String
  source           String        @default("upload")
  originalFileName String
  mimeType         String
  filePath         String
  vendor           String?
  receiptDate      DateTime?
  grossAmount      Decimal?
  netAmount        Decimal?
  vatAmount        Decimal?
  vatRate          Decimal?
  currency         String        @default("SEK")
  category         String?
  confidence       Decimal?
  needsReview      Boolean       @default(true)
  createdAt        DateTime      @default(now())
  receiptNumber    String?
  fxRateDate       DateTime?
  fxRateToSek      Decimal?
  sourceCurrency   String?
  itemPurchased    String?
  business         Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
}

model Transaction {
  id               String           @id @default(cuid())
  businessId       String
  receiptId        String?
  paidInvoiceId    String?          @unique
  txnDate          DateTime
  description      String
  direction        String
  grossAmount      Decimal
  netAmount        Decimal
  vatAmount        Decimal
  vatRate          Decimal
  currency         String           @default("SEK")
  source           String
  reference        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  fxRateDate       DateTime?
  fxRateToSek      Decimal?
  sourceCurrency   String?
  bankImportRows   BankImportRow[]
  creditNote       CreditNote?      @relation("CreditNoteTransaction")
  employeeExpenses EmployeeExpense?
  invoicePayment   InvoicePayment?  @relation("InvoicePartialPayment")
  lines            JournalLine[]
  salaryEntries    SalaryEntry?
  paidInvoice      Invoice?         @relation("InvoicePayment", fields: [paidInvoiceId], references: [id])
  receipt          Receipt?         @relation(fields: [receiptId], references: [id])
  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Invoice {
  id               String           @id @default(cuid())
  businessId       String
  customerId       String?
  invoiceNumber    String
  customerName     String
  customerEmail    String?
  customerPhone    String?
  customerWebsite  String?
  customerAddress  String?
  senderName       String?
  senderAddress    String?
  senderOrgNumber  String?
  senderEmail      String?
  senderPhone      String?
  senderWebsite    String?
  projectName      String?
  issueDate        DateTime
  dueDate          DateTime?
  description      String?
  notes            String?
  paymentMethod    String?
  paymentDetails   String?
  logoDataUrl      String?
  signatureDataUrl String?
  subtotalAmount   Decimal          @default(0)
  vatAmount        Decimal          @default(0)
  grossAmount      Decimal
  vatRate          Decimal          @default(0.25)
  currency         String           @default("SEK")
  status           String           @default("UNPAID")
  emailTo          String?
  sentAt           DateTime?
  paidAt           DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  creditNotes      CreditNote[]
  customer         Customer?        @relation(fields: [customerId], references: [id])
  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items            InvoiceItem[]
  payments         InvoicePayment[]
  paidTransaction  Transaction?     @relation("InvoicePayment")

  @@unique([businessId, invoiceNumber])
  @@index([businessId, issueDate])
  @@index([businessId, customerName])
}

model Customer {
  id           String    @id @default(cuid())
  businessId   String
  name         String
  email        String?
  phone        String?
  website      String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  postalCode   String?
  country      String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([businessId, name])
  @@index([businessId, email])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  sortOrder   Int      @default(0)
  description String
  quantity    Decimal  @default(1)
  unitPrice   Decimal
  vatMode     String   @default("NO_VAT")
  vatRate     Decimal  @default(0)
  netAmount   Decimal
  vatAmount   Decimal
  totalAmount Decimal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, sortOrder])
}

model InvoicePayment {
  id            String       @id @default(cuid())
  businessId    String
  invoiceId     String
  transactionId String?      @unique
  paymentDate   DateTime
  amount        Decimal
  currency      String       @default("SEK")
  reference     String?
  notes         String?
  createdAt     DateTime     @default(now())
  transaction   Transaction? @relation("InvoicePartialPayment", fields: [transactionId], references: [id])
  invoice       Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([businessId, paymentDate])
}

model CreditNote {
  id               String       @id @default(cuid())
  businessId       String
  invoiceId        String
  creditNoteNumber String
  issueDate        DateTime
  amount           Decimal
  vatAmount        Decimal      @default(0)
  netAmount        Decimal
  reason           String?
  status           String       @default("ISSUED")
  transactionId    String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  transaction      Transaction? @relation("CreditNoteTransaction", fields: [transactionId], references: [id])
  invoice          Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([businessId, creditNoteNumber])
  @@index([businessId, issueDate])
}

model JournalLine {
  id            String      @id @default(cuid())
  transactionId String
  accountId     String
  debit         Decimal     @default(0)
  credit        Decimal     @default(0)
  note          String?
  account       Account     @relation(fields: [accountId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model BankImportBatch {
  id           String          @id @default(cuid())
  businessId   String
  fileName     String
  importedRows Int
  acceptedRows Int
  rejectedRows Int
  createdAt    DateTime        @default(now())
  business     Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rows         BankImportRow[]
}

model FixedAsset {
  id                 String    @id @default(cuid())
  businessId         String
  description        String
  category           String    @default("equipment")
  acquisitionDate    DateTime
  acquisitionCost    Decimal
  depreciationMethod String    @default("declining_30")
  disposalDate       DateTime?
  disposalValue      Decimal?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  business           Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model MileageEntry {
  id              String   @id @default(cuid())
  businessId      String
  tripDate        DateTime
  destination     String
  purpose         String
  kilometers      Decimal
  ratePerKm       Decimal  @default(1.85)
  deductionAmount Decimal
  notes           String?
  createdAt       DateTime @default(now())
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, tripDate])
}

model PeriodisationEntry {
  id         String   @id @default(cuid())
  businessId String
  entryType  String
  direction  String
  taxYear    Int
  amount     Decimal
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, taxYear])
}

model OpeningBalance {
  id         String   @id @default(cuid())
  businessId String
  accountId  String
  fiscalYear Int
  amount     Decimal  @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, accountId, fiscalYear])
  @@index([businessId, fiscalYear])
}

model Employee {
  id                       String            @id @default(cuid())
  businessId               String
  employeeNumber           String?
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  personalNumber           String
  addressLine1             String?
  addressLine2             String?
  postalCode               String?
  city                     String?
  country                  String            @default("SE")
  taxTable                 String?
  preliminaryTaxRate       Decimal           @default(0.30)
  employerContributionRate Decimal           @default(0.3142)
  pensionRate              Decimal           @default(0.045)
  bankAccountName          String?
  bankClearingNumber       String?
  bankAccountNumber        String?
  iban                     String?
  bic                      String?
  status                   String            @default("ACTIVE")
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  business                 Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  expenses                 EmployeeExpense[]
  salaryEntries            SalaryEntry[]

  @@index([businessId, status])
  @@index([businessId, lastName, firstName])
}

model SalaryEntry {
  id                         String       @id @default(cuid())
  businessId                 String
  employeeId                 String
  payrollDate                DateTime
  periodFrom                 DateTime?
  periodTo                   DateTime?
  grossSalary                Decimal
  bonusAmount                Decimal      @default(0)
  overtimeAmount             Decimal      @default(0)
  benefitsAmount             Decimal      @default(0)
  taxableGross               Decimal
  preliminaryTaxRate         Decimal
  preliminaryTaxAmount       Decimal
  employerContributionRate   Decimal
  employerContributionAmount Decimal
  pensionRate                Decimal
  pensionAmount              Decimal
  netSalary                  Decimal
  status                     String       @default("DRAFT")
  approvedAt                 DateTime?
  paidAt                     DateTime?
  paymentReference           String?
  notes                      String?
  transactionId              String?      @unique
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  transaction                Transaction? @relation(fields: [transactionId], references: [id])
  employee                   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  business                   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, payrollDate])
  @@index([employeeId, payrollDate])
  @@index([businessId, status])
}

model EmployeeExpense {
  id               String       @id @default(cuid())
  businessId       String
  employeeId       String
  expenseDate      DateTime
  category         String
  description      String
  grossAmount      Decimal
  vatAmount        Decimal      @default(0)
  netAmount        Decimal
  currency         String       @default("SEK")
  status           String       @default("PENDING")
  approvedAt       DateTime?
  paidAt           DateTime?
  receiptReference String?
  paymentReference String?
  notes            String?
  transactionId    String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  transaction      Transaction? @relation(fields: [transactionId], references: [id])
  employee         Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  business         Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, expenseDate])
  @@index([employeeId, expenseDate])
  @@index([businessId, status])
}

model BankImportRow {
  id              String          @id @default(cuid())
  batchId         String
  rowNumber       Int
  txnDate         DateTime
  description     String
  amount          Decimal
  status          String
  rejectionReason String?
  transactionId   String?
  transaction     Transaction?    @relation(fields: [transactionId], references: [id])
  batch           BankImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}
